# Persistence mode:
# local  -> repositories use localStorage/IndexedDB
# remote -> repositories route to remote adapters
VITE_REPOSITORY_MODE=local
VITE_REPOSITORY_MODE_AUTH=local
VITE_REPOSITORY_MODE_INSPECTION=local
VITE_REPOSITORY_MODE_PHOTO=local

# Remote API base URL (required only for remote mode)
VITE_API_BASE_URL=

# Optional HTTP timeout in milliseconds
VITE_API_TIMEOUT_MS=15000
